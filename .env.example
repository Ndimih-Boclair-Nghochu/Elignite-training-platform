# Local SQLite example
# DATABASE_URL="file:./dev.db"

# Neon / Postgres production example
DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLER-HOST.neon.tech/elignite?sslmode=require&channel_binding=require"
DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@YOUR-DIRECT-HOST.neon.tech/elignite?sslmode=require&channel_binding=require"
# Temporary fallback if you only have the pooled URL at first:
# DIRECT_DATABASE_URL="postgresql://USER:PASSWORD@YOUR-POOLER-HOST.neon.tech/elignite?sslmode=require&channel_binding=require"

# Use a long random value in production
SESSION_SECRET="replace-with-a-long-random-production-secret"
